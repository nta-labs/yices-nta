(set-logic QF_NRA)
(set-info :status unsat)
(declare-fun x1 () Real)
(declare-fun x2 () Real)
(declare-fun sin (Real) Real)
(assert (< x1 2))
(assert (> x1 (- 2)))
(assert (< x2 10))
(assert (> x2 (- 10)))
(assert (< (+ (* (sin x1) (sin x1)) (* (sin x2) (sin x2))) 0.5))
(assert (= (- (* 2 x1) 1.5) x2))
(check-sat)
