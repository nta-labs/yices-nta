(set-logic QF_NRA)
(set-info :status unsat)
(declare-fun x () Real)
(declare-fun sin (Real) Real)
(assert (< x 6.6))
(assert (> x 5))
(assert (< (sin x) 0.7))
(assert (> (sin x) 0.4))
;(assert (= 0.25 (* (sin x) (sin x))))
(assert (>= 0.251 (* (sin x) (sin x))))
(assert (<= 0.249 (* (sin x) (sin x))))
(check-sat)
